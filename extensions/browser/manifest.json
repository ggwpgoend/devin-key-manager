{
  "manifest_version": 3,
  "name": "devin-key-manager helper",
  "version": "0.1.0",
  "description": "Sends Devin API keys from the Devin account page to your local devin-key-manager.",
  "author": "devin-key-manager contributors",
  "permissions": ["activeTab", "scripting", "storage", "clipboardRead"],
  "host_permissions": [
    "https://app.devin.ai/*",
    "http://localhost:5179/*",
    "http://127.0.0.1:5179/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send selection to devin-key-manager"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.devin.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
